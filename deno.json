{
  "fmt": {
    "exclude": [
      "./src/routeTree.gen.ts",
      "./prisma/generated/"
    ]
  },
  "lint": {
    "exclude": [
      "./src/routeTree.gen.ts",
      "./prisma/generated/"
    ],
    "rules": {
      "tags": [
        "recommended",
        "react",
        "jsx"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "imports": {
    "~/": "./",
    "@/": "./src/"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "module": "esnext",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ]
  },
  "allowScripts": [
    "npm:@prisma/engines@7.4.1",
    "npm:esbuild@0.27.3",
    "npm:fsevents@2.3.3",
    "npm:prisma@7.4.1"
  ],
  "unstable": [
    "temporal"
  ]
}
